{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:ecc:schemas:content_ops.render_job.v1",
  "title": "Content Ops Render Job Queue Payload v1",
  "description": "Stable worker queue payload for shortform content operations render jobs. Payloads contain storage keys and render metadata only; credentials and service secrets are intentionally excluded.",
  "type": "object",
  "required": [
    "schema_version",
    "workspace_id",
    "project_id",
    "user_id",
    "source_asset_id",
    "subscription_tier",
    "storage",
    "render"
  ],
  "properties": {
    "schema_version": {
      "const": "content_ops.render_job.v1"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "source_asset_id": {
      "type": "string",
      "minLength": 1
    },
    "subscription_tier": {
      "type": "string",
      "enum": [
        "free",
        "creator",
        "studio"
      ]
    },
    "storage": {
      "type": "object",
      "required": [
        "source_key",
        "audio_key",
        "transcript_key",
        "render_output_prefix"
      ],
      "properties": {
        "source_key": {
          "type": "string",
          "minLength": 1
        },
        "audio_key": {
          "type": "string",
          "minLength": 1
        },
        "transcript_key": {
          "type": "string",
          "minLength": 1
        },
        "render_output_prefix": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "render": {
      "type": "object",
      "required": [
        "render_engine",
        "brand_name",
        "audience",
        "clip_count",
        "platforms",
        "estimated_minutes",
        "template",
        "style_options",
        "caption_timeline",
        "source_assets",
        "composition",
        "output_settings"
      ],
      "properties": {
        "render_engine": {
          "const": "hyperframes"
        },
        "brand_name": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "clip_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 25
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "estimated_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "template": {
          "type": "object",
          "required": [
            "variant",
            "parameters"
          ],
          "properties": {
            "variant": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
            },
            "parameters": {
              "type": "object",
              "maxProperties": 50,
              "propertyNames": {
                "pattern": "^[a-z][a-z0-9_]{0,63}$"
              },
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 500
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  }
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "style_options": {
          "type": "object",
          "required": [
            "font_family",
            "brand_color",
            "caption_position",
            "overlay_position"
          ],
          "properties": {
            "font_family": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "brand_color": {
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            },
            "accent_color": {
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            },
            "caption_position": {
              "type": "string",
              "enum": [
                "top",
                "center",
                "bottom"
              ]
            },
            "overlay_position": {
              "type": "string",
              "enum": [
                "top",
                "center",
                "bottom",
                "left",
                "right"
              ]
            }
          },
          "additionalProperties": false
        },
        "caption_timeline": {
          "type": "array",
          "minItems": 1,
          "maxItems": 500,
          "items": {
            "type": "object",
            "required": [
              "start_ms",
              "end_ms",
              "text"
            ],
            "properties": {
              "start_ms": {
                "type": "integer",
                "minimum": 0
              },
              "end_ms": {
                "type": "integer",
                "minimum": 1
              },
              "text": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "speaker": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              }
            },
            "additionalProperties": false
          }
        },
        "source_assets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "role",
              "asset_id",
              "storage_key"
            ],
            "properties": {
              "role": {
                "const": "primary_video"
              },
              "asset_id": {
                "type": "string",
                "minLength": 1
              },
              "storage_key": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "composition": {
          "type": "object",
          "required": [
            "aspect_ratio",
            "width",
            "height",
            "fps"
          ],
          "properties": {
            "aspect_ratio": {
              "const": "9:16"
            },
            "width": {
              "const": 1080
            },
            "height": {
              "const": 1920
            },
            "fps": {
              "const": 30
            }
          },
          "additionalProperties": false
        },
        "output_settings": {
          "type": "object",
          "required": [
            "format",
            "video_codec",
            "audio_codec"
          ],
          "properties": {
            "format": {
              "const": "mp4"
            },
            "video_codec": {
              "const": "h264"
            },
            "audio_codec": {
              "const": "aac"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
