{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:ecc:schemas:content_ops.edit_brief.v1",
  "title": "Content Ops Edit Brief v1",
  "description": "Validated settings produced by the edit brief chat or default UI controls. This contract captures editing intent for deterministic planning and rendering without credentials or freeform worker instructions.",
  "type": "object",
  "required": [
    "schemaVersion",
    "goal",
    "tone",
    "pacing",
    "targetPlatforms",
    "include",
    "exclude",
    "clipLengthSeconds",
    "captionStyle",
    "cropStrategy",
    "music",
    "editorialRules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "content_ops.edit_brief.v1"
    },
    "goal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "tone": {
      "type": "string",
      "enum": [
        "educational",
        "funny",
        "authoritative",
        "casual",
        "dramatic",
        "inspirational"
      ]
    },
    "pacing": {
      "type": "string",
      "enum": [
        "slow",
        "balanced",
        "fast",
        "very_fast"
      ]
    },
    "targetPlatforms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "instagram_reels",
          "linkedin",
          "tiktok",
          "x",
          "youtube_shorts"
        ]
      }
    },
    "include": {
      "$ref": "#/definitions/momentConstraints"
    },
    "exclude": {
      "$ref": "#/definitions/momentConstraints"
    },
    "clipLengthSeconds": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 5,
          "maximum": 180
        },
        "max": {
          "type": "integer",
          "minimum": 5,
          "maximum": 180
        }
      },
      "additionalProperties": false
    },
    "captionStyle": {
      "type": "object",
      "required": [
        "preset",
        "density",
        "emoji"
      ],
      "properties": {
        "preset": {
          "type": "string",
          "enum": [
            "minimal",
            "bold",
            "karaoke",
            "subtitle"
          ]
        },
        "density": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "emoji": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "cropStrategy": {
      "type": "string",
      "enum": [
        "auto_subject",
        "center_crop",
        "manual_review",
        "screen_recording",
        "speaker_focus"
      ]
    },
    "music": {
      "type": "object",
      "required": [
        "mood",
        "allowLicensed"
      ],
      "properties": {
        "mood": {
          "type": "string",
          "enum": [
            "none",
            "upbeat",
            "calm",
            "dramatic",
            "lofi"
          ]
        },
        "allowLicensed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "editorialRules": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  },
  "definitions": {
    "momentConstraints": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "type": "object",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "startMs": {
            "type": "integer",
            "minimum": 0
          },
          "endMs": {
            "type": "integer",
            "minimum": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
